# Authentication
JWT_SECRET="your-super-secret-jwt-key-min-32-characters-long"


# Encryption at rest (CbtMessage.content) — 16+ символов, SHA-256 → AES-256-GCM
# Без ключа — plaintext (обратная совместимость)
ENCRYPTION_KEY=""

# Google OAuth – Login / Register with Gmail
# Use GOOGLE_* (no NEXT_PUBLIC_). Add exact redirect URI in Google Cloud Console.
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
# Callback URL – must match Google Console. Production: https://yourdomain.com/api/auth/callback/google
GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/callback/google"
# Optional: used if GOOGLE_REDIRECT_URI is not set (e.g. https://talktodaisy.com)
NEXT_PUBLIC_APP_URL="https://talktodaisy.com"

# SEO: код подтверждения сайта в Google Search Console (опционально)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Database
DATABASE_URL="postgresql://username:password@localhost:5432/database_name"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Email (рассылка): приоритет — Azure Communication Services, иначе Mailgun
# Azure Communication Services (рекомендуется)
AZURE_COMMUNICATION_CONNECTION_STRING="endpoint=https://xxx.communication.azure.com/;accesskey=..."
AZURE_COMMUNICATION_EMAIL_SENDER="doNotReply@xxx.azurecomm.net"
# Mailgun (запасной вариант)
MAILGUN_API_KEY="your_mailgun_api_key"
MAILGUN_DOMAIN="your_mailgun_domain"

# Google Analytics
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID="G-XXXXXXXXXX"

# AI API Configuration – Azure ML inference endpoint (CRITICAL for /chat)
# Expects: POST with Bearer token; body: { message, user_id, max_tokens, temperature, history }
# Response: { response, language?, model? }
NEXT_PUBLIC_AI_API_URL="https://daisy-therapy.westus2.inference.ml.azure.com/score"
NEXT_PUBLIC_AI_API_KEY="your-azure-ml-primary-key"

# Azure ML Configuration (CBT Therapy API)
# Weekly report, dynamics insights — cbtApi.getWeeklyReport(), getDynamicsInsights()
# - Azure Web App (proxy): use /chat — e.g. cbt-therapy-api-daisy...azurewebsites.net
# - Azure ML direct: use /score — e.g. daisy-therapy...inference.ml.azure.com (auto-detected)
CBT_API_URL="http://cbt-therapy-api-daisy-ergpf5fecjeheub5.centralus-01.azurewebsites.net"
CBT_API_KEY="apiendpointformyapplication"
CBT_API_TIMEOUT="30000"  # Request timeout in milliseconds (default: 30000)
