    "@prisma/extension-accelerate": "^2.0.2",
    "@radix-ui/react-slot": "^1.0.2",
    "ai": "^5.0.49",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "form-data": "^4.0.4",
    "framer-motion": "^11.0.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.544.0",
    "mailgun.js": "^10.2.0",
    "next": "^14.2.0",
