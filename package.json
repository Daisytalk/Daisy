{
  "name": "daisy-landing-page",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "cross-env NODE_ENV=production next build",
    "build:standalone": "cross-env NODE_ENV=production next build && npm run copy-standalone",
    "copy-standalone": "cp -r .next/standalone ./ && cp -r public ./standalone/ && cp -r .next/static ./standalone/.next/static/",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@ai-sdk/google": "^2.0.15",
    "@ai-sdk/react": "^2.0.49",
    "@google/genai": "^1.20.0",
