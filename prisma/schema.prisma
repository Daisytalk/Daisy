generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String            @id @default(cuid())
  email              String            @unique
  name               String?
  password           String
  googleId           String?           @unique
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  isOnboarded          Boolean           @default(false)
  subscriptionStatus   String            @default("trial")
  aiProfile            Json?             @map("ai_profile")
  conversationMemory   Json?             @map("conversation_memory")
  passwordResetToken   String?           @unique @map("password_reset_token")
  passwordResetExpires DateTime?         @map("password_reset_expires")
  deactivatedAt        DateTime?         @map("deactivated_at")
  currentStressRating  Int?              @map("current_stress_rating") // 1-5, для weekly report
  locale              String?           @default("en")
  timezone            String?
  /** Нормализованный источник: instagram, vk, direct, utm-метка и т.д. */
  acquisitionSource   String?           @map("acquisition_source")
  /** UTM/referrer подробности */
  acquisitionDetail     String?           @map("acquisition_detail")
  aiSessions             AiSession[]
  cbtConversations       CbtConversation[]
  onboarding             OnboardingData?
  psychProfileSnapshots  PsychProfileSnapshot[]
  userPreferences        UserPreferences?
  memoryItems            MemoryItem[]
  conversationState      ConversationState?
  premiumOfferLogs      PremiumOfferLog[]
  stressRatings            StressRating[]
  weeklyReportSnapshots    WeeklyReportSnapshot[]
  interventionFeedbacks InterventionFeedback[]
  payments              Payment[]

  @@index([acquisitionSource])
  @@map("users")
}

/// Последний сохранённый недельный отчёт (summary + рекомендации) по периоду 7d / 14d / 30d
model WeeklyReportSnapshot {
  id                      String   @id @default(cuid())
  userId                  String
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  period                  String
  summary                 String   @db.Text
  /// { "en": "...", "ru": "..." } — параллельно с AI; summary — legacy/фолбэк
  summaryI18n             Json?    @map("summary_i18n")
  /// string[] | { "en": string[], "ru": string[] }
  insights                Json
  /// string[] | { "en": string[], "ru": string[] }
  recommendations       Json
  /// Тексты «Daisy notices» по метрикам (emotion, stress, energy, support) для DetailedDynamics; optional.
  dynamicsMetricInsights  Json?    @map("dynamics_metric_insights")
  source                  String   @default("ai")
  locale                  String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@unique([userId, period])
  @@index([userId])
  @@map("weekly_report_snapshots")
}

model OnboardingData {
  id        String   @id @default(cuid())
  userId    String   @unique
  responses Json
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("onboarding_data")
}

model PsychProfileSnapshot {
  id         String   @id @default(cuid())
  userId     String
  ESI        Float    // Emotional Stability Index 0-100
  BSI        Float    // Burnout & Stress Index 0-100
  SSI        Float    // Social Support Index 0-100
  PVI        Float    // Physical Vulnerability Index 0-100
  MRI        Float    // Meaning & Resource Index 0-100
  riskLevel  String   @map("risk_level") // critical | high | medium | low
  cluster    String?  // психотип/архетип
  flags      Json?    // high_anxiety, sleep_issues, etc.
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("psych_profile_snapshots")
}

model AiSession {
  id        String   @id @default(cuid())
  userId    String
  messages  Json
  context   Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ai_sessions")
}

/** Успешные списания (Freedom Pay, позже — Stripe и др.) */
model Payment {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  amountMinor Int      @map("amount_minor")
  currency    String   @default("USD")
  provider    String   @default("freedompay")
  externalId  String   @unique @map("external_id")
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("payments")
}

model Newsletter {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())

  @@map("newsletter")
}

model TokenBlacklist {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model CbtConversation {
  id        String       @id @default(cuid())
  userId    String
  sessionId String?
  persona   String       @default("active_listener")
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  CbtMessage[]

  @@index([userId])
  @@index([sessionId])
  @@map("cbt_conversations")
}

model CbtMessage {
  id             String          @id @default(cuid())
  conversationId String
  role           String
  content        String
  protocol       String?
  diagnosis      String[]
  persona        String?
  daisyState     String?         @map("daisy_state")
  isAnonymized   Boolean         @default(false) @map("is_anonymized")
  piiDetected    Boolean         @default(false) @map("pii_detected")
  createdAt      DateTime        @default(now())
  conversation   CbtConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("cbt_messages")
}

model PiiAuditLog {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  messageId   String?  @map("message_id")
  entityTypes String[] @map("entity_types") // типы, НЕ значения
  layer       String   // L1_REGEX | L2_PRESIDIO
  detectedAt  DateTime @default(now()) @map("detected_at")

  @@index([userId, detectedAt])
  @@map("pii_audit_logs")
}

// ─── Memory Architecture (3 layers) ───────────────────────────────────────────

model UserPreferences {
  id              String   @id @default(cuid())
  userId          String   @unique
  preferredStyles  Json?    @map("preferred_styles") // array of style ids
  boundaries      Json?    // { "avoid_topics": [], "sensitive": [] }
  goalsTop2       Json?    @map("goals_top2") // array of 2 goals from onboarding
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

model MemoryItem {
  id            String   @id @default(cuid())
  userId        String
  type          String   // event | belief | relationship | health | habit
  topic         String   // work | relationship | anxiety | sleep | self-worth | planning | etc.
  valence       Int?     // -2..+2
  intensity     Int?     // 0..3
  summary       String   @db.Text
  evidence      String?  @db.Text
  confidence    Float?   // 0..1
  ttlDays       Int?     @map("ttl_days")
  isPinned      Boolean  @default(false) @map("is_pinned")
  consentScope  String?  @map("consent_scope") // core | personal | sensitive
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, topic])
  @@index([userId, createdAt])
  @@map("memory_items")
}

model ConversationState {
  id                String   @id @default(cuid())
  userId            String   @unique
  lastSessionSummary String? @map("last_session_summary") @db.Text
  lastSessionAt     DateTime? @map("last_session_at")
  rollingState      Json?    @map("rolling_state") // { lastMood, lastStress, arousal, valence }
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("conversation_state")
}

// ─── Premium & Outcome Loop ──────────────────────────────────────────────────

model PremiumOfferLog {
  id          String   @id @default(cuid())
  userId      String
  triggerType String   @map("trigger_type") // P1 | P2 | P3 | P4 | P5
  offerShownAt DateTime @default(now()) @map("offer_shown_at")
  dismissed   Boolean  @default(false)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, offerShownAt])
  @@map("premium_offer_logs")
}

model StressRating {
  id        String   @id @default(cuid())
  userId    String
  rating    Int?     // 1-5 (post_session)
  source    String?  // post_session | daily_checkin
  date      DateTime @default(now()) // calendar date for daily check-in
  emotion   Int?     // daily_checkin: 0–100 index (UI sliders 1–5 saved as 20–100; legacy 1–5 still read)
  stress    Int?
  energy    Int?
  support   Int?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt])
  @@index([userId, date])
  @@map("stress_ratings")
}

model InterventionFeedback {
  id           String   @id @default(cuid())
  userId       String
  rating       Int      // 1-5 "Стало легче?"
  helped       Boolean? // "Это помогло?" Да/Нет
  protocolType String?  @map("protocol_type") // stabilize | regulate | solve
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("intervention_feedbacks")
}
