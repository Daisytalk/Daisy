// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String   @id @default(cuid())
  email              String   @unique
  name               String?
  password           String
  googleId           String?  @unique
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  isOnboarded        Boolean  @default(false)
  subscriptionStatus String   @default("trial")

  // Relations
  onboarding     OnboardingData?
  aiSessions     AiSession[]
  cbtConversations CbtConversation[]

  @@map("users")
}
model OnboardingData {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Onboarding responses (JSON for flexibility)
  responses Json
  completed Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("onboarding_data")
}

model AiSession {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Session data
  messages Json
  context  Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ai_sessions")
}

model Newsletter {
  id    String @id @default(cuid())
  email String @unique

  createdAt DateTime @default(now())

  @@map("newsletter")
}

model TokenBlacklist {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model CbtConversation {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  CbtMessage[]
  sessionId String?
  persona   String      @default("active_listener")
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([userId])
  @@index([sessionId])
  @@map("cbt_conversations")
}

model CbtMessage {
  id             String          @id @default(cuid())
  conversationId String
  conversation   CbtConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String          // "user" or "assistant"
  content        String          @db.Text
  
  // CBT-specific metadata
  protocol       String?
  diagnosis      String[]
  persona        String?
  
  createdAt      DateTime        @default(now())

  @@index([conversationId])
  @@map("cbt_messages")
}
